# Copy this file to `.env` and fill in your Alpaca API credentials.
# `.env` is git-ignored; never commit real credentials.
#
# Generate keys in the Alpaca dashboard (use paper-trading keys for the examples):
#   https://app.alpaca.markets/

# Required — Alpaca API key id and secret (the names the SDK auto-resolves).
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Optional — used only by examples/marketdata-backend.ts.
# Port the SSE server listens on (default: 8080).
PORT=8080
# Comma-separated symbols to stream (default: AAPL,MSFT).
SYMBOLS=AAPL,MSFT
