{
  "name": "alpaca-ts-alpha-tooling",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Reproducible OpenAPI regeneration pipeline for @alpacahq/alpaca-ts-alpha (Trading + Market Data).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate": "tsx src/cli.ts",
    "jar:fetch": "bash scripts/ensure-jar.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.38.0",
    "@types/node": "^22.20.0",
    "fast-json-patch": "^3.1.1",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
