{
  "name": "@alpacahq/alpaca-ts-alpha",
  "version": "0.0.0",
  "description": "TypeScript SDK for the Alpaca Trading and Market Data APIs (generated).",
  "license": "Apache-2.0",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "rest": ["./dist/rest.d.ts"],
      "testing": ["./dist/testing.d.ts"]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./rest": {
      "import": {
        "types": "./dist/rest.d.mts",
        "default": "./dist/rest.mjs"
      },
      "require": {
        "types": "./dist/rest.d.ts",
        "default": "./dist/rest.js"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.mts",
        "default": "./dist/testing.mjs"
      },
      "require": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit && npm run typecheck:examples",
    "typecheck:examples": "tsc --noEmit -p tsconfig.examples.json",
    "test": "vitest run",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "ws": "^8.21.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@microsoft/api-extractor": "^7.58.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
